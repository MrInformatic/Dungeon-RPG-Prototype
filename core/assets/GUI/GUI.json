        Bat:{runspeed:1,animationspeed:0.1,radius:8,cooldown:0.5,distance:false,maxlive:100,lookradius:120},
    }

    rpg.dungeon.Entity.Player.Inventory.Inventory$InventoryStyle:{
        Armor:{background:InventarArmor,darker:darker},
        Potions:{background:InventarPotions,darker:darker},
    }

    com.badlogic.gdx.scenes.scene2d.ui.Label$LabelStyle: {
    	description: { font: default }
    }

    com.badlogic.gdx.scenes.scene2d.ui.ScrollPane$ScrollPaneStyle: {
    	description: {background:InventarArmorDescription}
    }

    rpg.dungeon.Entity.Player.Inventory.Item.ItemsHolderPane$ItemsHolderPaneStyle:{
        armoritems: {background:InventarArmorItems,selector:ArmorHolderSelector,selectorsteps:27}
    }


    rpg.dungeon.Entity.Player.Player$PlayerStyle:{
        FireMage:{actionsHolder:"Fire",dispenserspakage:"rpg.dungeon.Entity.Player.FireMage",dispensersnames:["BombDispenser","FlameDispenser","FireDispenser","SplashDispenser"],font:default,color:FireMage},
    }

    rpg.dungeon.Entity.Player.Inventory.Item.ItemsHolder$ItemsHolderStyle:{
        armor:{itemsHolder:ArmorHolder},
