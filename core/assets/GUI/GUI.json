    rpg.dungeon.Engine.GUI.DifferenceBar$DifferenceBarStyle:{
        armor:{Background:ArmorvalueBG,Bar:Armorvalue,less:Armorvalueless,more:Armorvaluemore,start:0,end:90}
    }

    rpg.dungeon.Engine.Drawable.DrawableBar$BarStyle:{
        Opponent:{Background:BarBG,Bar:Bar,start:0,end:12}
    }

    rpg.dungeon.Entity.Player.ActionsHolder$ActionsHolderStyle:{
        Fire:{Background:Actionsholder,actionsnames:["Bomb","Flame","Fire","Splash"]},
    }

    rpg.dungeon.Entity.Player.PotionsHolder$PotionsHolderStyle:{
        default:{Background:Potionsholder},
    }

    rpg.dungeon.Entity.Opponents.Opponent$OpponentSettings:{
