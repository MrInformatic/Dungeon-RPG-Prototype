    rpg.dungeon.Engine.GUI.Bar$BarStyle:{
        rot:{Background:BarrotBG,Bar:Barrot,start:31,end:93},
        cyan:{Background:BarcyanBG,Bar:Barcyan,start:31,end:93},
        blau:{Background:BarblauBG,Bar:Barblau,start:31,end:93},
        grun:{Background:BargrunBG,Bar:Bargrun,start:31,end:93},
        gelb:{Background:BargelbBG,Bar:Bargelb,start:31,end:93},
        orange:{Background:BarorangeBG,Bar:Barorange,start:31,end:93},
        lila:{Background:BarlilaBG,Bar:Barlila,start:31,end:93}
        Flame:{Background:Flame,Bar:Action,start:0,end:24,vert:true}
        Bomb:{Background:Explosion,Bar:Action,start:0,end:24,vert:true}
        Fire:{Background:Fire,Bar:Action,start:0,end:24,vert:true}
        Splash:{Background:Splash,Bar:Action,start:0,end:24,vert:true}
